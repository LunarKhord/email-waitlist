# ------------------------------------
# 1. Dependency and Environment Management (uv)
# ------------------------------------

# The virtual environment directory created by uv
# This should always be ignored as it contains your project dependencies
# 'uv' typically creates this as '.venv'
.venv/

# Lock files generated by uv (if you use uv compile or uv lock)
uv.lock

# Pip/other standard environment folders (just in case)
env/
venv/
__pypackages__/

# ------------------------------------
# 2. Python-specific Files
# ------------------------------------

# Bytecode files
*.pyc
__pycache__/

# Python build artifacts
*.egg-info/
.eggs/
dist/
build/
pip-log.txt
pip-delete-this-directory.txt

# Installer logs
*.log
*.egg
*.whl

# ------------------------------------
# 3. Development and Editor Files
# ------------------------------------

# IDE files (e.g., VS Code, IntelliJ/PyCharm)
.idea/
.vscode/settings.json
.vscode/launch.json
.vscode/tasks.json

# Local config and environment variables (CRITICAL)
# This file holds secrets (API keys, database URLs)
.env
.env.*
!.env.example # Keep the example file if you have one

# ------------------------------------
# 4. FastAPI/Uvicorn Specific
# ------------------------------------

# Uvicorn/ASGI server logs or temporary files
*.sqlite3 # If you use SQLite for development/testing
db.sqlite3